{
  "model": "copilot/gpt-4.1",
  "models": {
    "openai/gpt-5.1": { "reasoning_effort": "medium" },
    "codex/gpt-5.3-codex": { "reasoning_effort": "medium" }
  },
  "aliases": {
    "codex-high": { "name": "codex/gpt-5.3-codex", "reasoning_effort": "high" },
    "codex-medium": {
      "name": "codex/gpt-5.3-codex",
      "reasoning_effort": "medium"
    }
  },
  "auto_continue": true,
  "context": {
    "max_tool": 250,
    "keep": 50,
    "clear_input": true
  },
  "skills": ["monitor-logs", "tmux-interactive"],
  "agents": ["code/review", "code/explore"],
  "permission": {
    "deny": {
      "bash": {
        "arguments": {
          "command": ["^rm", "\\&\\&\\s*rm"]
        }
      }
    },
    "allow": {
      "bash": {
        "arguments": {
          "command": ["^git diff", "^git status", "^git log"]
        }
      },
      "grep": {
        "arguments": {
          "pattern": [".*"],
          "glob": ["\\.lua$"]
        }
      },
      "read": {
        "arguments": {
          "path": ["\\.lua$", "README\\.md$"]
        }
      },
      "fetch": {
        "arguments": {
          "url": [
            "^https://github\\.com/",
            "^https://raw\\.githubusercontent\\.com/"
          ]
        }
      }
    }
  }
}
